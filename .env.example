# Proxy config (optional) — copy this file to ".env" and fill it in.
#
# Use a SESSION-STICKY RESIDENTIAL endpoint (e.g. DataImpulse, IPRoyal,
# Smartproxy, Bright Data). Do NOT use a rotating IP — Facebook ties the session
# token to the IP it was issued on, so rotating mid-run breaks it.
#
# After filling these, tick "Route through proxy" in the web UI.

# host:port of the proxy gateway, e.g. gw.dataimpulse.com:823
PROXY_SERVER=

# Auth for the proxy. For sticky sessions the username often encodes the session
# id, e.g. user__cr.us;sessid.abc123 — check your provider's docs.
PROXY_USERNAME=
PROXY_PASSWORD=

# Optional: override the web server port (default 5174).
# PORT=5174
